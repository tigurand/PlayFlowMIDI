<Window x:Class="PlayFlowMIDI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PlayFlowMIDI" Height="760" Width="1250" MinHeight="650" MinWidth="1050"
        Background="#121212">

    <Window.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- ================= MAIN AREA ================= -->

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.5*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= PLAYLIST ================= -->

            <Border Grid.Column="0" Background="#1B1B1B" CornerRadius="8" Padding="12" Margin="0,0,10,0">

                <DockPanel>

                    <!-- FOLDER SECTION -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Folder Path" Foreground="#CCCCCC" Margin="0,0,0,4"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="FolderPathTextBox" Grid.Column="0" Height="26" VerticalContentAlignment="Center" Margin="0,0,8,0" TextChanged="SaveTrigger"/>
                            <Button Grid.Column="1" Content="Load Folder" Height="26" Margin="0,0,8,0" Padding="10,0" Click="LoadFolder_Click"/>
                            <Button Grid.Column="2" Content="Reload" Width="70" Height="26" Margin="0,0,200,0" ToolTip="Reload folders" Click="ReloadSongs_Click"/>
                            <Button Grid.Column="3" Content="+" Width="32" Height="26" Margin="0,0,8,0" ToolTip="Add MIDI files" Click="AddSongs_Click"/>
                            <Button Grid.Column="4" Content="-" Width="32" Height="26" ToolTip="Remove selected MIDI files" Click="RemoveSongs_Click"/>
                        </Grid>
                    </StackPanel>

                    <!-- TOOLBAR SECTION -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- MAIN TOOLBAR ROW -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT SIDE CONTROLS -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Search" Foreground="#CCCCCC" FontSize="11"/>
                                    <TextBox x:Name="SearchTextBox" Width="350" Height="26" VerticalContentAlignment="Center" ToolTip="Search songs in the current playlist" TextChanged="SearchTextBox_TextChanged"/>
                                </StackPanel>

                                <TextBlock x:Name="SongCountText" Text="0 songs loaded" Foreground="#BBBBBB" VerticalAlignment="Bottom" Margin="0,0,12,0" ToolTip="Total songs currently in the playlist"/>

                            </StackPanel>

                            <!-- RIGHT SIDE SORT CONTROLS (STICKS TO WINDOW RIGHT) -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Sort By" Foreground="#CCCCCC" FontSize="11"/>
                                    <ComboBox x:Name="SortByComboBox" Width="160" Height="26" ToolTip="Choose how the playlist is sorted" SelectionChanged="SortBy_SelectionChanged">
                                        <ComboBoxItem Content="Name" IsSelected="True"/>
                                        <ComboBoxItem Content="Custom Order"/>
                                        <ComboBoxItem Content="Recently Added"/>
                                        <ComboBoxItem Content="Duration"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel>
                                    <Button x:Name="SortDirectionButton" Content="▲" FontSize="14" FontWeight="Bold" Width="40" Height="26" Margin="0,14,0,0" ToolTip="Ascending order" Click="SortDirectionButton_Click"/>
                                </StackPanel>

                            </StackPanel>

                        </Grid>
                    </Grid>

                    <!-- PLAYLIST TABLE -->
                    <ListView x:Name="PlaylistListView" Background="#1B1B1B" BorderThickness="0" SizeChanged="PlaylistListView_SizeChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Extended" AllowDrop="True" PreviewMouseLeftButtonDown="PlaylistListView_PreviewMouseLeftButtonDown" MouseMove="PlaylistListView_MouseMove" Drop="PlaylistListView_Drop" SelectionChanged="PlaylistListView_SelectionChanged" MouseDoubleClick="PlaylistListView_MouseDoubleClick">
                        <ListView.Resources>
                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" Width="480" DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="BPM" Width="60" DisplayMemberBinding="{Binding BPM}"/>
                                <GridViewColumn Header="Time Added" Width="210" DisplayMemberBinding="{Binding TimeAdded}"/>
                                <GridViewColumn Header="Duration" Width="80" DisplayMemberBinding="{Binding Duration}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                </DockPanel>

            </Border>

            <!-- ================= RIGHT PANEL ================= -->

            <StackPanel Grid.Column="1">

                <!-- APPLICATION -->
                <GroupBox Header="Application" Foreground="White" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="8">
                        <Button Content="Settings" Width="90" Height="26" Margin="0,0,10,0" Click="OpenSettings" ToolTip="Open application settings"/>
                        <Button Content="Profiles" Width="90" Click="OpenProfiles" ToolTip="Open game profiles"/>
                    </StackPanel>
                </GroupBox>

                <!-- PLAYBACK -->
                <GroupBox Header="Playback" Foreground="White" Margin="0,0,0,10">
                    <StackPanel Margin="8">
                        <RadioButton x:Name="PlayOnceRadio" Content="Play Once" Foreground="White" IsChecked="True" Checked="SaveTrigger"/>
                        <RadioButton x:Name="RepeatSongRadio" Content="Repeat Song" Foreground="White" Checked="SaveTrigger"/>
                        <RadioButton x:Name="RepeatPlaylistRadio" Content="Repeat Playlist" Foreground="White" Checked="SaveTrigger"/>
                        <RadioButton x:Name="RandomPlaylistRadio" Content="Random Playlist" Foreground="White" Checked="SaveTrigger"/>
                    </StackPanel>
                </GroupBox>

                <!-- TRACKS -->
                <GroupBox Header="Tracks" Foreground="White" Margin="0,0,0,10">
                    <ScrollViewer Height="220">
                        <StackPanel x:Name="TracksStackPanel" Margin="8">
                            <!-- Tracks will be dynamically populated here -->
                            <TextBlock Text="No song selected" Foreground="#888888" FontStyle="Italic"/>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>

                <!-- Speed and Pitch Adjustment Section -->
                <GroupBox Header="Playback Adjustment" Foreground="White">
                    <StackPanel Margin="8">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Speed" Foreground="#CCCCCC"/>
                            
                            <DockPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                <TextBox x:Name="SpeedTextBox" DockPanel.Dock="Right" Width="50" Height="22" Margin="10,0,0,0" VerticalContentAlignment="Center" Text="1.00" TextChanged="SpeedTextBox_TextChanged"/>
                                <Slider x:Name="SpeedSlider" Minimum="0.1" Maximum="3.0" Value="1.0" SmallChange="0.01" LargeChange="0.1" ValueChanged="SpeedSlider_ValueChanged" IsMoveToPointEnabled="True"/>
                            </DockPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Pitch / Transpose" Foreground="#CCCCCC"/>
                            
                            <DockPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                <TextBox x:Name="PitchTextBox" DockPanel.Dock="Right" Width="50" Height="22" Margin="10,0,0,0" VerticalContentAlignment="Center" Text="0" TextChanged="PitchTextBox_TextChanged"/>
                                <Slider x:Name="PitchSlider" Minimum="-24" Maximum="24" Value="0" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="PitchSlider_ValueChanged" IsMoveToPointEnabled="True"/>
                            </DockPanel>
                        </Grid>

                        <Button Content="Reset Adjustments" Height="26" Margin="0,15,0,0" Click="ResetAdjustments_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- Profile and Key Mode Section -->
                <GroupBox Header="Active Profile" Foreground="White" Margin="0,10,0,0">
                    <StackPanel Margin="8">
                        <ComboBox x:Name="ActiveProfileComboBox" Height="26" Margin="0,0,0,8" SelectionChanged="ActiveProfileComboBox_SelectionChanged"/>
                        
                        <TextBlock Text="Key Mode" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,4"/>
                        <StackPanel>
                            <RadioButton x:Name="MainMode37" Content="37 Keys" Foreground="White" Checked="MainModeChanged" Visibility="Collapsed"/>
                            <RadioButton x:Name="MainMode36" Content="36 Keys" Foreground="White" Checked="MainModeChanged" Visibility="Collapsed"/>
                            <RadioButton x:Name="MainMode15" Content="15 Keys" Foreground="White" Checked="MainModeChanged" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>

        </Grid>

        <!-- ================= PLAYER ================= -->

        <Border Grid.Row="1" Background="#181818" CornerRadius="8" Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- SONG TITLE -->
                <TextBlock x:Name="PlayingSongTitle" Grid.Row="0" Text="No song playing" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>

                <!-- TIME -->
                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Slider x:Name="PlaybackSlider" Height="24" Thumb.DragStarted="PlaybackSlider_DragStarted" Thumb.DragCompleted="PlaybackSlider_DragCompleted" ValueChanged="PlaybackSlider_ValueChanged" IsMoveToPointEnabled="True"/>
                    <TextBlock x:Name="PlaybackTimeText" Text="0:00 / 0:00" Foreground="#BBBBBB" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- CONTROLS -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="PrevButton" Content="⏮" Width="40" Height="36" Margin="6" Click="PrevButton_Click"/>
                    <Button x:Name="PlayPauseButton" Content="▶" Width="40" Height="36" Margin="6" Background="#1DB954" Foreground="Black" BorderThickness="0" Click="PlayPauseButton_Click"/>
                    <Button x:Name="PreviewButton" Content="🎧" Width="40" Height="36" Margin="6" ToolTip="Preview Song (Play in App)" Click="PreviewButton_Click"/>
                    <Button x:Name="StopButton" Content="⏹" Width="40" Height="36" Margin="6" Click="StopButton_Click"/>
                    <Button x:Name="NextButton" Content="⏭" Width="40" Height="36" Margin="6" Click="NextButton_Click"/>
                </StackPanel>

            </Grid>

        </Border>
        
        <!-- ================= SETTINGS UI ================= -->

        <Grid x:Name="SettingsUI"
      Background="#121212"
      Visibility="Collapsed"
      Panel.ZIndex="100"
      Grid.RowSpan="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="10,10,10,0">

                <!-- Back button -->
                <Button Content="← Back"
                Width="90"
                Height="30"
                Click="CloseSettings"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"/>

                <!-- True centered title -->
                <TextBlock Text="Settings"
                FontSize="20"
                Foreground="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

            </Grid>

            <!-- SETTINGS CONTENT -->
            <StackPanel Grid.Row="1" Margin="10">

                <!-- SHORTCUTS -->
                <GroupBox Header="Keyboard Shortcuts" Foreground="White" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Play / Pause" Foreground="White" Grid.Row="0"/>
                        <TextBox x:Name="ShortcutPlayPause" Text="Ctrl+F1" Grid.Row="0" Grid.Column="1" TextChanged="SaveTrigger" PreviewKeyDown="Shortcut_KeyDown" IsReadOnly="True" Cursor="Hand" ToolTip="Click and press keys to set shortcut. Backspace to clear."/>

                        <TextBlock Text="Stop" Foreground="White" Grid.Row="1"/>
                        <TextBox x:Name="ShortcutStop" Text="Ctrl+F2" Grid.Row="1" Grid.Column="1" TextChanged="SaveTrigger" PreviewKeyDown="Shortcut_KeyDown" IsReadOnly="True" Cursor="Hand" ToolTip="Click and press keys to set shortcut. Backspace to clear."/>

                        <TextBlock Text="Previous Song" Foreground="White" Grid.Row="2"/>
                        <TextBox x:Name="ShortcutPrev" Text="Ctrl+F3" Grid.Row="2" Grid.Column="1" TextChanged="SaveTrigger" PreviewKeyDown="Shortcut_KeyDown" IsReadOnly="True" Cursor="Hand" ToolTip="Click and press keys to set shortcut. Backspace to clear."/>

                        <TextBlock Text="Next Song" Foreground="White" Grid.Row="3"/>
                        <TextBox x:Name="ShortcutNext" Text="Ctrl+F4" Grid.Row="3" Grid.Column="1" TextChanged="SaveTrigger" PreviewKeyDown="Shortcut_KeyDown" IsReadOnly="True" Cursor="Hand" ToolTip="Click and press keys to set shortcut. Backspace to clear."/>

                        <TextBlock Text="Preview Song" Foreground="White" Grid.Row="4"/>
                        <TextBox x:Name="ShortcutPreview" Text="Ctrl+F5" Grid.Row="4" Grid.Column="1" TextChanged="SaveTrigger" PreviewKeyDown="Shortcut_KeyDown" IsReadOnly="True" Cursor="Hand" ToolTip="Click and press keys to set shortcut. Backspace to clear."/>

                        <TextBlock Text="Toggle Playback Mode" Foreground="White" Grid.Row="5"/>
                        <TextBox x:Name="ShortcutToggleMode" Text="Ctrl+F6" Grid.Row="5" Grid.Column="1" TextChanged="SaveTrigger" PreviewKeyDown="Shortcut_KeyDown" IsReadOnly="True" Cursor="Hand" ToolTip="Click and press keys to set shortcut. Backspace to clear."/>
                    </Grid>
                </GroupBox>

                <!-- OCTAVE HANDLING -->
                <GroupBox Header="Octave Handling" Foreground="White" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="OctaveDefaultRadio" Content="Default (Play MIDI as is)" Foreground="White" IsChecked="True" Checked="SaveTrigger"/>
                        <RadioButton x:Name="OctaveWrapRadio" Content="Wrap (Wrap notes into allowed octave range)" Foreground="White" Checked="SaveTrigger"/>
                        <RadioButton x:Name="OctaveClampRadio" Content="Clamp (Clamp notes to nearest allowed octave)" Foreground="White" Checked="SaveTrigger"/>
                    </StackPanel>
                </GroupBox>

                <!-- PLAYBACK OPTIONS -->
                <GroupBox Header="Playback Options" Foreground="White" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="TrimLeadingSilenceCheck" Content="Trim leading silence" Foreground="White" IsChecked="True" Margin="0,0,0,5" Click="SaveTrigger"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <CheckBox x:Name="HoldNotesCheck" Content="Hold notes" Foreground="White" IsChecked="True" VerticalAlignment="Center" Click="SaveTrigger"/>
                            <TextBlock Text="Release Delay (ms):" Foreground="White" Margin="20,0,5,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="ReleaseDelayTextBox" Text="20" Width="40" Height="20" VerticalContentAlignment="Center" TextChanged="SaveTrigger"/>
                        </StackPanel>

                        <CheckBox x:Name="DisablePercussionCheck" Content="Disable percussion by default" Foreground="White" IsChecked="True" Margin="0,0,0,5" Click="SaveTrigger"/>

                        <CheckBox x:Name="AutoAdapt15KeysCheck" Content="Automatically adapt to 15 keys" Foreground="White" IsChecked="False" Click="SaveTrigger" ToolTip="Only works when '15 Keys' mode is selected."/>
                    </StackPanel>
                </GroupBox>

                <!-- MIDI INPUT -->
                <GroupBox Header="MIDI Input Device" Foreground="White" Margin="0,0,0,10">
                    <Grid Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="MidiInputComboBox"
                                Width="500"
                                Height="26"
                                Margin="0,0,8,0"
                                SelectionChanged="MidiInputComboBox_SelectionChanged"/>   

                            <Button Content="Refresh"
                                Width="80"
                                Height="26"
                                Click="RefreshMidiInputDevices_Click"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- APPLICATION -->
                <GroupBox Header="Application" Foreground="White" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="AlwaysOnTopCheck" Content="Always on top" Foreground="White" Click="SaveTrigger"/>
                    </StackPanel>
                </GroupBox>

                <!-- UPDATES -->
                <GroupBox Header="Updates" Foreground="White">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="AutoUpdateCheck"
                                  Content="Enable auto-update (GitHub releases)"
                                  Foreground="White"
                                  Margin="0,0,0,5"
                                  Click="SaveTrigger"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Button Content="Check for Updates"
                                    Width="150"
                                    Height="26"
                                    Click="CheckUpdates_Click"/>
                            <TextBlock x:Name="UpdateStatusText"
                                       Text="Not checked"
                                       Foreground="#BBBBBB"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>

        </Grid>

        <!-- ================= PROFILES UI ================= -->

        <Grid x:Name="ProfilesUI"
        Background="#121212"
        Visibility="Collapsed"
        Panel.ZIndex="100"
        Grid.RowSpan="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PROFILE LIST -->
            <Border Grid.Column="0" Background="#1B1B1B" Padding="10">

                <DockPanel>

                    <TextBlock Text="Game Profiles"
                       FontSize="18"
                       Foreground="White"
                       Margin="0,0,0,10"
                       DockPanel.Dock="Top"/>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">

                        <Button Content="+ Add Custom Profile"
                        Height="30"
                        Margin="0,0,0,6"
                        Click="AddProfile_Click"/>

                        <Button x:Name="DeleteProfileButton"
                        Content="Delete Profile"
                        Height="30"
                        Click="DeleteProfile_Click"/>

                    </StackPanel>

                    <ListBox x:Name="ProfileList"
                     SelectionChanged="ProfileList_Changed">
                    </ListBox>

                </DockPanel>

            </Border>


            <!-- PROFILE EDITOR -->
            <Grid Grid.Column="1" Margin="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0">

                    <Button Content="← Back"
                    Width="90"
                    Height="30"
                    Click="CloseProfiles"
                    HorizontalAlignment="Left"/>

                    <TextBlock x:Name="ProfileSettingsTitle"
                       Text="Profile Settings"
                       FontSize="20"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                </Grid>

                <StackPanel Grid.Row="1" x:Name="ProfileNameEditPanel" Margin="0,15,0,0" Visibility="Collapsed">
                    <TextBlock Text="Profile Name:" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox x:Name="ProfileNameBox" Height="26" TextChanged="ProfileNameBox_TextChanged"/>
                </StackPanel>


                <!-- GAME DETECTION -->
                <GroupBox Header="Game Detection"
                  Foreground="White"
                  Grid.Row="2"
                  Margin="0,15,0,10">

                    <StackPanel Margin="10">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Executable Name:"
                               Width="140"
                               Foreground="White"/>
                            <TextBox x:Name="ExeNameBox"
                             Width="220" TextChanged="SaveTrigger"/>
                        </StackPanel>

                        <CheckBox x:Name="SwitchToWindowCheck"
                          Content="Automatically switch to game window"
                          Foreground="White" Click="SaveTrigger"/>

                        <CheckBox x:Name="AutoPauseCheck"
                          Content="Automatically pause when game is inactive"
                          Foreground="White" Margin="0,5,0,0" Click="SaveTrigger"/>

                    </StackPanel>

                </GroupBox>


                <!-- MODE -->
                <GroupBox Header="Mode"
                  Foreground="White"
                  Grid.Row="3"
                  Margin="0,0,0,10">

                    <StackPanel Margin="10">

                        <RadioButton x:Name="Mode37"
                             Content="37 Keys"
                             Checked="ModeChanged"
                             Foreground="White" Click="SaveTrigger"/>

                        <RadioButton x:Name="Mode36"
                             Content="36 Keys"
                             Checked="ModeChanged"
                             Foreground="White" Click="SaveTrigger"/>

                        <RadioButton x:Name="Mode15"
                             Content="15 Keys"
                             Checked="ModeChanged"
                             Foreground="White" Click="SaveTrigger"/>

                    </StackPanel>

                </GroupBox>


                <!-- ================= KEY MAPPING LAYOUT ================= -->

                <GroupBox Header="Key Mapping"
                Foreground="White"
                Grid.Row="4">
                <GroupBox.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="IsReadOnly" Value="True"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="ToolTip" Value="Click and press keys to set mapping. Backspace to clear."/>
                    </Style>
                </GroupBox.Resources>

                <DockPanel Margin="8">

                <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,6,0,0">

                <Button Content="Reset to Default"
                Width="140"
                Height="28"
                Click="ResetToDefault_Click"/>

                </StackPanel>


                        <!-- ================= WWM 36 KEYS (BASE LAYOUT) ================= -->

                        <StackPanel x:Name="WWMKeys36" Visibility="Collapsed" TextBox.PreviewKeyDown="Shortcut_KeyDown">

                            <UniformGrid x:Name="WWMGrid1" Columns="12" Width="744" HorizontalAlignment="Left">

                                <TextBox Width="56" Height="28" Margin="3" Text="Q" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Shift+Q" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="W" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Ctrl+E" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="E" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="R" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Shift+R" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="T" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Shift+T" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Y" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Ctrl+U" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="U" TextChanged="SaveTrigger"/>

                            </UniformGrid>


                            <UniformGrid x:Name="WWMGrid2" Columns="12" Width="744" HorizontalAlignment="Left">

                                <TextBox Width="56" Height="28" Margin="3" Text="A" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Shift+A" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="S" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="Ctrl+D" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="D" TextChanged="SaveTrigger"/>
                                <TextBox Width="56" Height="28" Margin="3" Text="F" TextChanged="SaveTrigger"/>
