<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Version>1.0.3.0</Version>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>PlayFlowMIDI.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="PlayFlowMIDI.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Melanchall.DryWetMidi" Version="8.0.3" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="PlayFlowMIDI.ico" />
  </ItemGroup>

  <Target Name="ZipRelease" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <ZipDirectory
      SourceDirectory="$(OutputPath)"
      DestinationFile="$(OutputPath)..\PlayFlowMIDI-v$(Version).zip"
      Overwrite="true" />
  </Target>

</Project>
